# Copy to ".streamlit/secrets.toml" for LOCAL runs, OR paste into the
# Streamlit Community Cloud "Secrets" box. NEVER commit the real secrets.toml.

# ---- OpenAI ----
OPENAI_API_KEY = "sk-...your-real-key..."
OPENAI_MODEL = "gpt-4o"
OPENAI_RESEARCH_MODEL = "gpt-4o"
ENABLE_WEB_SEARCH = "true"
ADMIN_MARGIN = "0.28"

# ---- Login (choose ONE style) ----
# A) Single shared password:
APP_PASSWORD = "choose-a-strong-password"

# B) OR multiple named users (this takes priority over APP_PASSWORD if present).
#    Uncomment to use:
# [passwords]
# ali  = "ali-strong-pw"
# sara = "sara-strong-pw"
