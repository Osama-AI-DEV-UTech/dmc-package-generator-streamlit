# ============================================================
#  DMC Package Generator — Environment
#  Copy to ".env" and fill in your OpenAI key.
# ============================================================

# --- OpenAI (the ONLY external API used) --------------------
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model for the JSON-structuring step (must support JSON mode).
OPENAI_MODEL=gpt-4o
# Model for the web-research / references step.
OPENAI_RESEARCH_MODEL=gpt-4o

# Live web search for real price references.
#   true  -> uses OpenAI Responses API web_search tool (real sources)
#   false -> best-effort estimates, no live URLs
ENABLE_WEB_SEARCH=true
WEB_SEARCH_TOOL=web_search        # fallback handled automatically

# --- Generation tuning --------------------------------------
RESEARCH_MAX_TOKENS=6000
STRUCTURE_MAX_TOKENS=8000

# --- Business defaults --------------------------------------
DEFAULT_CURRENCY=USD
DEFAULT_MIN_HOTEL_STARS=3
# Platform selling margin applied to net (DMC) price for admin* fields, e.g. 0.28 = +28%
ADMIN_MARGIN=0.28

# --- Wiring -------------------------------------------------
# Streamlit uses this to reach the FastAPI backend.
BACKEND_URL=http://localhost:8000

# Default number of distinct packages per request (1-10)
DEFAULT_PACKAGE_COUNT=3
